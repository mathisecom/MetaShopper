{% comment %}
  Section Shopify : Comment fonctionne l'imprimante thermique ? — Avisi
  - Grille sur ordinateur
  - Étapes empilées sur mobile
  - Branding par défaut : #FF4713 / #FFF8F5
  - Tous les contenus et styles sont modifiables dans l’éditeur Shopify
{% endcomment %}

<section
  id="avisi-thermal-steps-{{ section.id }}"
  class="avisi-thermal-steps"
  style="
    --avisi-bg: {{ section.settings.background_color }};
    --avisi-accent: {{ section.settings.accent_color }};
    --avisi-title: {{ section.settings.title_color }};
    --avisi-text: {{ section.settings.text_color }};
    --avisi-muted: {{ section.settings.muted_color }};
    --avisi-grid-line: {{ section.settings.grid_line_color }};
    --avisi-number-text: {{ section.settings.number_text_color }};
    --avisi-max-width: {{ section.settings.max_width }}px;
    --avisi-columns: {{ section.settings.desktop_columns }};
    --avisi-gap: {{ section.settings.desktop_gap }}px;
  "
>
  <div class="avisi-thermal-steps__inner">
    <header class="avisi-thermal-steps__header">
      {% if section.settings.heading != blank %}
        <h2 class="avisi-thermal-steps__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <p class="avisi-thermal-steps__subtitle">
          {{ section.settings.subtitle | escape }}
        </p>
      {% endif %}
    </header>

    {% if section.blocks.size > 0 %}
      <div class="avisi-thermal-steps__grid">
        {% for block in section.blocks %}
          <article
            class="avisi-thermal-steps__item"
            {{ block.shopify_attributes }}
          >
            <div
              class="avisi-thermal-steps__number"
              aria-hidden="true"
            >
              {{ block.settings.number | default: forloop.index }}
            </div>

            {% if block.settings.title != blank %}
              <h3 class="avisi-thermal-steps__item-title">
                {{ block.settings.title | escape }}
              </h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="avisi-thermal-steps__item-text rte">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="avisi-thermal-steps__empty">
        Ajoutez des étapes depuis l’éditeur de thème.
      </div>
    {% endif %}
  </div>
</section>

{% style %}
  #avisi-thermal-steps-{{ section.id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: var(--avisi-bg);
    color: var(--avisi-text);
  }

  #avisi-thermal-steps-{{ section.id }}::before {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--avisi-grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--avisi-grid-line) 1px, transparent 1px);
    background-size:
      {{ section.settings.grid_size }}px
      {{ section.settings.grid_size }}px;
    content: "";
    pointer-events: none;
    opacity: {{ section.settings.grid_opacity | divided_by: 100.0 }};
  }

  #avisi-thermal-steps-{{ section.id }} * {
    box-sizing: border-box;
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__inner {
    position: relative;
    z-index: 1;
    width: min(calc(100% - 40px), var(--avisi-max-width));
    margin: 0 auto;
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__header {
    max-width: {{ section.settings.header_max_width }}px;
    margin: 0 auto {{ section.settings.header_bottom_spacing }}px;
    text-align: center;
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__heading {
    margin: 0;
    color: var(--avisi-title);
    font-size: clamp(
      {{ section.settings.heading_size_mobile }}px,
      3vw,
      {{ section.settings.heading_size_desktop }}px
    );
    font-weight: {{ section.settings.heading_weight }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    letter-spacing: -0.03em;
    text-transform: {% if section.settings.heading_uppercase %}uppercase{% else %}none{% endif %};
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__subtitle {
    margin: 14px 0 0;
    color: var(--avisi-muted);
    font-size: {{ section.settings.subtitle_size_desktop }}px;
    font-weight: {{ section.settings.subtitle_weight }};
    line-height: 1.5;
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__grid {
    display: grid;
    grid-template-columns: repeat(var(--avisi-columns), minmax(0, 1fr));
    align-items: start;
    gap: var(--avisi-gap);
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__item {
    display: flex;
    min-width: 0;
    min-height: {{ section.settings.item_min_height }}px;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: {{ section.settings.item_padding_vertical }}px {{ section.settings.item_padding_horizontal }}px;
    text-align: center;
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__number {
    display: grid;
    width: {{ section.settings.number_size }}px;
    height: {{ section.settings.number_size }}px;
    place-items: center;
    margin-bottom: {{ section.settings.number_bottom_spacing }}px;
    background: var(--avisi-accent);
    border-radius: {{ section.settings.number_radius }}px;
    box-shadow:
      0 {{ section.settings.number_shadow_y }}px {{ section.settings.number_shadow_blur }}px
      rgba(255, 71, 19, {{ section.settings.number_shadow_opacity | divided_by: 100.0 }});
    color: var(--avisi-number-text);
    font-size: {{ section.settings.number_font_size }}px;
    font-weight: 800;
    line-height: 1;
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__item-title {
    margin: 0;
    color: var(--avisi-title);
    font-size: {{ section.settings.item_title_size_desktop }}px;
    font-weight: {{ section.settings.item_title_weight }};
    line-height: 1.3;
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__item-text {
    max-width: {{ section.settings.item_text_max_width }}px;
    margin-top: 12px;
    color: var(--avisi-text);
    font-size: {{ section.settings.item_text_size_desktop }}px;
    font-weight: {{ section.settings.item_text_weight }};
    line-height: {{ section.settings.item_text_line_height | divided_by: 100.0 }};
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__item-text > * {
    margin-top: 0;
    margin-bottom: 0;
  }

  #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__empty {
    padding: 32px;
    border: 1px dashed var(--avisi-grid-line);
    border-radius: 16px;
    color: var(--avisi-muted);
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__grid {
      grid-template-columns: repeat({{ section.settings.tablet_columns }}, minmax(0, 1fr));
      gap: {{ section.settings.tablet_gap }}px;
    }
  }

  @media screen and (max-width: 749px) {
    #avisi-thermal-steps-{{ section.id }} {
      padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px;
    }

    #avisi-thermal-steps-{{ section.id }}::before {
      background-size:
        {{ section.settings.grid_size_mobile }}px
        {{ section.settings.grid_size_mobile }}px;
    }

    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__inner {
      width: min(calc(100% - 28px), var(--avisi-max-width));
    }

    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__header {
      margin-bottom: {{ section.settings.header_bottom_spacing_mobile }}px;
    }

    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__subtitle {
      margin-top: 10px;
      font-size: {{ section.settings.subtitle_size_mobile }}px;
    }

    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__grid {
      grid-template-columns: 1fr;
      gap: {{ section.settings.mobile_gap }}px;
    }

    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__item {
      min-height: 0;
      padding: {{ section.settings.item_padding_vertical_mobile }}px {{ section.settings.item_padding_horizontal_mobile }}px;
    }

    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__number {
      margin-bottom: {{ section.settings.number_bottom_spacing_mobile }}px;
    }

    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__item-title {
      font-size: {{ section.settings.item_title_size_mobile }}px;
    }

    #avisi-thermal-steps-{{ section.id }} .avisi-thermal-steps__item-text {
      max-width: {{ section.settings.item_text_max_width_mobile }}px;
      margin-top: 10px;
      font-size: {{ section.settings.item_text_size_mobile }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Étapes imprimante Avisi",
  "tag": "section",
  "class": "section-avisi-thermal-steps",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "COMMENT FONCTIONNE L'IMPRIMANTE THERMIQUE ?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "4 étapes simples pour créer et imprimer vos étiquettes"
    },
    {
      "type": "checkbox",
      "id": "heading_uppercase",
      "label": "Afficher le titre en majuscules",
      "default": true
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fond de la section",
      "default": "#FFF8F5"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur des numéros",
      "default": "#FF4713"
    },
    {
      "type": "color",
      "id": "number_text_color",
      "label": "Couleur des chiffres",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur des titres",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur des textes",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Couleur du sous-titre",
      "default": "#4B4B4B"
    },
    {
      "type": "color",
      "id": "grid_line_color",
      "label": "Couleur du quadrillage",
      "default": "#E9DDD8"
    },
    {
      "type": "header",
      "content": "Disposition"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximale",
      "min": 900,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "range",
      "id": "header_max_width",
      "label": "Largeur maximale de l’en-tête",
      "min": 500,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 900
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Colonnes sur ordinateur",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "tablet_columns",
      "label": "Colonnes sur tablette",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "desktop_gap",
      "label": "Espace entre les étapes sur ordinateur",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "tablet_gap",
      "label": "Espace entre les étapes sur tablette",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Espace entre les étapes sur mobile",
      "min": 12,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "item_min_height",
      "label": "Hauteur minimale d’une étape sur ordinateur",
      "min": 160,
      "max": 360,
      "step": 10,
      "unit": "px",
      "default": 220
    },
    {
      "type": "range",
      "id": "item_padding_vertical",
      "label": "Marge verticale interne sur ordinateur",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "item_padding_horizontal",
      "label": "Marge horizontale interne sur ordinateur",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "item_padding_vertical_mobile",
      "label": "Marge verticale interne sur mobile",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "item_padding_horizontal_mobile",
      "label": "Marge horizontale interne sur mobile",
      "min": 8,
      "max": 36,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Quadrillage"
    },
    {
      "type": "range",
      "id": "grid_size",
      "label": "Taille du quadrillage sur ordinateur",
      "min": 40,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "grid_size_mobile",
      "label": "Taille du quadrillage sur mobile",
      "min": 30,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "grid_opacity",
      "label": "Opacité du quadrillage",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "%",
      "default": 18
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Taille du titre sur ordinateur",
      "min": 28,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Taille du titre sur mobile",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse du titre",
      "default": "700",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-gras" },
        { "value": "700", "label": "Gras" },
        { "value": "800", "label": "Très gras" }
      ]
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Interligne du titre",
      "min": 90,
      "max": 140,
      "step": 5,
      "unit": "%",
      "default": 110
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "label": "Taille du sous-titre sur ordinateur",
      "min": 13,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "label": "Taille du sous-titre sur mobile",
      "min": 13,
      "max": 21,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "subtitle_weight",
      "label": "Graisse du sous-titre",
      "default": "400",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-gras" }
      ]
    },
    {
      "type": "range",
      "id": "item_title_size_desktop",
      "label": "Titre des étapes sur ordinateur",
      "min": 15,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 19
    },
    {
      "type": "range",
      "id": "item_title_size_mobile",
      "label": "Titre des étapes sur mobile",
      "min": 15,
      "max": 26,
      "step": 1,
      "unit": "px",
      "default": 19
    },
    {
      "type": "select",
      "id": "item_title_weight",
      "label": "Graisse des titres d’étape",
      "default": "700",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-gras" },
        { "value": "700", "label": "Gras" },
        { "value": "800", "label": "Très gras" }
      ]
    },
    {
      "type": "range",
      "id": "item_text_size_desktop",
      "label": "Texte des étapes sur ordinateur",
      "min": 14,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "item_text_size_mobile",
      "label": "Texte des étapes sur mobile",
      "min": 14,
      "max": 21,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "item_text_weight",
      "label": "Graisse du texte des étapes",
      "default": "400",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-gras" }
      ]
    },
    {
      "type": "range",
      "id": "item_text_line_height",
      "label": "Interligne du texte des étapes",
      "min": 120,
      "max": 190,
      "step": 5,
      "unit": "%",
      "default": 155
    },
    {
      "type": "range",
      "id": "item_text_max_width",
      "label": "Largeur maximale du texte sur ordinateur",
      "min": 180,
      "max": 460,
      "step": 10,
      "unit": "px",
      "default": 320
    },
    {
      "type": "range",
      "id": "item_text_max_width_mobile",
      "label": "Largeur maximale du texte sur mobile",
      "min": 220,
      "max": 520,
      "step": 10,
      "unit": "px",
      "default": 360
    },
    {
      "type": "header",
      "content": "Numéros"
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Taille du carré",
      "min": 44,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "number_radius",
      "label": "Arrondi du carré",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "number_font_size",
      "label": "Taille du chiffre",
      "min": 16,
      "max": 34,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "number_bottom_spacing",
      "label": "Espace sous le numéro sur ordinateur",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "number_bottom_spacing_mobile",
      "label": "Espace sous le numéro sur mobile",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "number_shadow_y",
      "label": "Décalage vertical de l’ombre",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "number_shadow_blur",
      "label": "Flou de l’ombre",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "number_shadow_opacity",
      "label": "Opacité de l’ombre",
      "min": 0,
      "max": 35,
      "step": 1,
      "unit": "%",
      "default": 18
    },
    {
      "type": "header",
      "content": "Espacements de la section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute sur ordinateur",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse sur ordinateur",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "header_bottom_spacing",
      "label": "Espace sous l’en-tête sur ordinateur",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Marge haute sur mobile",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Marge basse sur mobile",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "header_bottom_spacing_mobile",
      "label": "Espace sous l’en-tête sur mobile",
      "min": 16,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Numéro",
          "default": "1"
        },
        {
